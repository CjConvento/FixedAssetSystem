@model FixedAssetSystem.Models.FixedAssetRequest

@{
    ViewData["Title"] = "Edit Fixed Asset Request";

    // Create a list of simple objects without navigation properties
    var existingUnitsForJson = Model.ExistingUnitDetails?.OrderBy(e => e.ItemNo).Select(e => new
    {
        itemNo = e.ItemNo,
        description = e.Description,
        location = e.Location,
        userName = e.UserName,
        remarks = e.Remarks
    }).ToList();
}

<h1>Edit Fixed Asset Request</h1>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />
    <div class="row">
        <div class="col-md-6">
            <div class="form-group">
                <label asp-for="Department" class="control-label"></label>
                <input asp-for="Department" class="form-control" required />
                <span asp-validation-for="Department" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Section" class="control-label"></label>
                <input asp-for="Section" class="form-control" required />
                <span asp-validation-for="Section" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="TargetDateNeeded" class="control-label"></label>
                <input asp-for="TargetDateNeeded" class="form-control" type="date" required />
                <span asp-validation-for="TargetDateNeeded" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Quantity" class="control-label"></label>
                <input asp-for="Quantity" class="form-control" type="number" min="1" required />
                <span asp-validation-for="Quantity" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="AssetType" class="control-label"></label>
                <input asp-for="AssetType" class="form-control" required />
                <span asp-validation-for="AssetType" class="text-danger"></span>
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-group">
                <label asp-for="DetailedDescription" class="control-label"></label>
                <textarea asp-for="DetailedDescription" class="form-control" rows="3" required></textarea>
                <span asp-validation-for="DetailedDescription" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ReasonPurpose" class="control-label"></label>
                <textarea asp-for="ReasonPurpose" class="form-control" rows="3" required></textarea>
                <span asp-validation-for="ReasonPurpose" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ProposedLocation" class="control-label"></label>
                <input asp-for="ProposedLocation" class="form-control" />
                <span asp-validation-for="ProposedLocation" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="EstimatedLifeSpan" class="control-label"></label>
                <input asp-for="EstimatedLifeSpan" class="form-control" placeholder="e.g., 3-5 years" />
                <span asp-validation-for="EstimatedLifeSpan" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="RequestType" class="control-label"></label>
                <select asp-for="RequestType" class="form-control" required>
                    <option value="">-- Select --</option>
                    <option value="New">New</option>
                    <option value="Additional">Additional</option>
                    <option value="Replacement">Replacement</option>
                </select>
                <span asp-validation-for="RequestType" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="DamagedReportNo" class="control-label">Damaged Report No (if Replacement)</label>
                <input asp-for="DamagedReportNo" class="form-control" />
                <span asp-validation-for="DamagedReportNo" class="text-danger"></span>
            </div>
        </div>
    </div>

    <!-- REQUESTED BY (readonly, from session) -->
    <div class="form-group">
        <label asp-for="RequestedByName" class="control-label">Requested By (Initiator)</label>
        <input asp-for="RequestedByName" class="form-control" readonly />
        <span asp-validation-for="RequestedByName" class="text-danger"></span>
    </div>

    <!-- EVALUATED BY (text input) -->
    <div class="form-group">
        <label asp-for="EvaluatedByName" class="control-label">Evaluated By (Head/Manager)</label>
        <input asp-for="EvaluatedByName" class="form-control" required />
        <span asp-validation-for="EvaluatedByName" class="text-danger"></span>
    </div>

    <!-- EXISTING UNIT DETAILS (only for Additional) -->
    <div id="existingUnitsSection" style="display: none; margin-top: 20px;">
        <div class="section-title">EXISTING UNIT DETAILS</div>
        <table id="existingUnitsTable" class="table table-bordered">
            <thead>
                <tr>
                    <th>Item No.</th>
                    <th>Description</th>
                    <th>Location</th>
                    <th>User</th>
                    <th>Remarks (Condition)</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (Model.RequestType == "Additional" && Model.ExistingUnitDetails != null && Model.ExistingUnitDetails.Any())
                {
                    var units = Model.ExistingUnitDetails.OrderBy(e => e.ItemNo).ToList();
                    for (int i = 0; i < units.Count; i++)
                    {
                        var unit = units[i];
                        <tr>
                            <td><input type="number" name="ExistingUnits[@i].ItemNo" class="form-control item-no" value="@unit.ItemNo" /></td>
                            <td><input type="text" name="ExistingUnits[@i].Description" class="form-control description" value="@unit.Description" required /></td>
                            <td><input type="text" name="ExistingUnits[@i].Location" class="form-control location" value="@unit.Location" /></td>
                            <td><input type="text" name="ExistingUnits[@i].UserName" class="form-control user-name" value="@unit.UserName" /></td>
                            <td><input type="text" name="ExistingUnits[@i].Remarks" class="form-control remarks" value="@unit.Remarks" /></td>
                            <td><button type="button" class="btn btn-danger btn-sm removeRow">Remove</button></td>
                        </tr>   
                    }
                }
                else
                    {
                        <tr>
                            <td colspan="6" style="color:red;">
                                DEBUG: No existing units found.<br />
                                RequestType = @Model.RequestType<br />
                                ExistingUnitDetails is @(Model.ExistingUnitDetails == null ? "NULL" : $"Count = {Model.ExistingUnitDetails.Count()}")
                            </td>
                        </tr>
                    }
            </tbody>
        </table>
        <button type="button" id="addUnitRow" class="btn btn-sm btn-secondary">Add Another Unit</button>
    </div>

    <div class="form-group mt-3">
        <input type="submit" value="Save Changes" class="btn btn-primary" />
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        // Project existing units to a simple object without navigation cycles
        @{
                var existingUnitsForJson = Model.ExistingUnitDetails?.OrderBy(e => e.ItemNo).Select(e => new
                {
                        itemNo = e.ItemNo,
                        description = e.Description,
                        location = e.Location,
                        userName = e.UserName,
                        remarks = e.Remarks
                }).ToList();
        }
        window.fixedAssetEdit = {
            requestType: '@Model.RequestType',
            existingUnits: @Html.Raw(Json.Serialize(existingUnitsForJson))
        };
    </script>
    <script src="~/js/edit.js"></script>
}