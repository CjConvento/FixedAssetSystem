@model FixedAssetSystem.Models.LoginViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Login - Fixed Asset System</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="login-body">
    <div class="login-card">
        <h2>Fixed Asset System</h2>
        <form asp-action="Login" method="post">
            <div asp-validation-summary="ModelOnly" class="error"></div>
            <div class="form-group">
                <label asp-for="EmployeeNo"></label>
                <input asp-for="EmployeeNo" class="form-control" placeholder="e.g., HS9501-0019" />
                <span asp-validation-for="EmployeeNo" class="error"></span>
            </div>
            <div class="form-group">
                <label asp-for="Password"></label>
                <input asp-for="Password" class="form-control" type="password" placeholder="(password = hstpass)" />
                <span asp-validation-for="Password" class="error"></span>
            </div>  
            <button type="submit" class="btn-login">Login</button>
        </form>
        <div class="text-muted">
            Use your Employee No. from the Employees HST Database (e.g., HS9501-0019)
        </div>
    </div>
</body>
</html>